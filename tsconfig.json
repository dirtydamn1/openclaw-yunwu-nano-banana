{
  "include": ["src/**/*"],
  "exclude": ["./node_modules/**", "./dist/**"],
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"],
    "noImplicitThis": true,
    "jsx": "preserve",
    "allowJs": true,
    "importHelpers": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "useUnknownInCatchVariables": false,
    "noImplicitAny": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false
  }
}